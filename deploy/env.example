# 서버(211.110.140.201)용 .env 예시
# 이 파일을 프로젝트 루트에 .env 로 복사한 뒤 값을 채우세요.

SECRET_KEY=여기에-랜덤-시크릿키-입력
DJANGO_DEBUG=false

# 사이트 연결 (소셜 로그인 콜백·관리자 "사이트 보기"용). 설정 후: python manage.py setup_site
SITE_DOMAIN=s2022.co.kr
SITE_NAME=굴삭기나라

# 이메일(비밀번호 찾기 등, 선택)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=앱비밀번호
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
